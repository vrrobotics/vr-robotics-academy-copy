---
import AppRouter from "@/components/Router";

// Allow server-side rendering for API endpoints like Razorpay
export const prerender = false;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>VR Robotics Academy</title>
    <script>
      // Handle redirect from 404.html
      if (sessionStorage.redirect) {
        const redirect = sessionStorage.redirect;
        delete sessionStorage.redirect;
        // Navigate using React Router by updating URL
        const base = import.meta.env.BASE_URL || '/';
        window.history.replaceState(null, null, `${base}${redirect.replace(/^\//, '')}`);
      }
    </script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #f5f5f5;
      }
      #root {
        width: 100%;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <div id="root">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>
