---
import AppRouter from "@/components/Router";

export const prerender = true;

export async function getStaticPaths() {
  // Add all demo routes and other client-side routes
  const routes = [
    { params: { slug: undefined } }, // Home
    // Demo Routes
    { params: { slug: 'demo/admin-dashboard' } },
    { params: { slug: 'demo/teacher-dashboard' } },
    { params: { slug: 'demo/student-dashboard' } },
    // Public Routes (No Login)
    { params: { slug: 'admin-dashboard-public' } },
    { params: { slug: 'teacher-dashboard-public' } },
    { params: { slug: 'student-dashboard-public' } },
    // Auth Routes
    { params: { slug: 'login' } },
    { params: { slug: 'student-signup' } },
    { params: { slug: 'teacher-login' } },
    { params: { slug: 'teacher-signup' } },
    // Dashboard Routes (Protected)
    { params: { slug: 'student-dashboard' } },
    { params: { slug: 'student-dashboard-new' } },
    { params: { slug: 'student-dashboard-final' } },
    { params: { slug: 'teacher-dashboard' } },
    { params: { slug: 'admin-dashboard' } },
    { params: { slug: 'admin-dashboard-new' } },
  ];
  return routes;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>VR Robotics Academy</title>
    <script>
      // Handle redirect from 404.html
      if (sessionStorage.redirect) {
        const redirect = sessionStorage.redirect;
        delete sessionStorage.redirect;
        // Navigate using React Router by updating URL
        const base = import.meta.env.BASE_URL || '/';
        window.history.replaceState(null, null, `${base}${redirect.replace(/^\//, '')}`);
      }
    </script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #f5f5f5;
      }
      #root {
        width: 100%;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <div id="root">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>
