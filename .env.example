# Gmail SMTP Configuration
# Get Gmail App Password: https://myaccount.google.com/app-passwords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Admin email where demo and registration notifications are sent
ADMIN_EMAIL=your-email@gmail.com

# Razorpay (client + server)
# VITE_ value is public and used by checkout.js on frontend.
# Server keys must never be exposed in client-side code.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Note: Copy this file to .env.local and add your actual Gmail credentials
